---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../lib/i18n';

const { slug } = Astro.params;
const locale = 'pt-br';
const title = slug ? decodeURIComponent(slug) : 'Artigo';
---

<PageLayout title={title} locale={locale}>
  <slot name="header">
    <h1>{title}</h1>
  </slot>
  <p>{t('article.no_articles', locale)}</p>
</PageLayout>

---
import PageLayout from '../../layouts/PageLayout.astro';
import { t } from '../../lib/i18n';
---

<PageLayout title={t('nav.search', 'pt-br')} locale="pt-br">
  <slot name="header"><h1>{t('nav.search', 'pt-br')}</h1></slot>
  <form action="/pt-br/search" method="get" role="search">
    <input type="search" name="q" placeholder={t('search.placeholder', 'pt-br')} />
    <button type="submit">{t('nav.search', 'pt-br')}</button>
  </form>
  <p>{t('search.no_results', 'pt-br')}</p>
</PageLayout>

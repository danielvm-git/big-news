---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <main class="home">
    <section class="hero">
      <h1>big-news</h1>
      <p class="hero-tagline">Um CMS de notícias open-source com PostgreSQL</p>
    </section>
  </main>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 1rem;
  }
  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }
  .hero-tagline {
    color: #666;
    font-size: 1.125rem;
  }
</style>
